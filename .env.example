# Copy to .env.local and fill in. .env.local is gitignored.

# Google AI (Gemini) — https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=

# Supabase — Settings > API in your Supabase project dashboard
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Secret — server only, bypasses Row Level Security. Do not expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
